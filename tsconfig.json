{
  "compilerOptions": {
    "target": "ES2025",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["ES2025"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["src"],
  "exclude": ["src/__tests__", "dist", "node_modules"]
}
